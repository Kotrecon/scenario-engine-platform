{
  "Kestrel": {
    "Endpoints": {
      "Api": {
        "Url": "http://0.0.0.0:8080"
      },
      "Health": {
        "Url": "http://0.0.0.0:8081"
      }
    }
  },
  "Jwt": {
    "Issuer": "ScenarioDesigner",
    "Audience": "ScenarioDesigner"
  },
  "Cors": {
    "AllowedOrigins": ["https://your-frontend.example.com"]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  }
}
